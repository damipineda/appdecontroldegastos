{
  "name": "appdecontroldegastos",
  "version": "1.1.2",
  "description": "Aplicación web para gestionar finanzas personales, controlar gastos, ingresos, deudas y presupuestos.",
  "main": "index.js",
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "android:icons": "node scripts/sync-android-icons.mjs",
    "android:version": "node scripts/sync-android-version.mjs",
    "android:publish": "node scripts/publish-apk.mjs",
    "cap:init": "npx cap init \"Finanzas Personales\" \"com.damipineda.finanzas\" --web-dir=www",
    "cap:sync": "npm run build:web && npx cap sync android",
    "android:build": "npm run android:icons && npm run cap:sync && npm run android:version && cd android && gradlew.bat assembleDebug && cd .. && npm run android:publish",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damipineda/appdecontroldegastos.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/damipineda/appdecontroldegastos/issues"
  },
  "homepage": "https://github.com/damipineda/appdecontroldegastos#readme",
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capgo/capacitor-social-login": "^8.3.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0"
  }
}
